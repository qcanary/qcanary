{
  "name": "@qcanary/agent",
  "version": "0.1.1",
  "description": "BullMQ queue monitoring agent for QCanary that streams job metadata without sharing Redis credentials",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bullmq",
    "redis",
    "monitoring",
    "queue",
    "observability",
    "job-queue"
  ],
  "author": "Qcanary",
  "homepage": "https://qcanary.dev/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/qcanary/qcanary.git",
    "directory": "packages/agent"
  },
  "license": "MIT",
  "peerDependencies": {
    "bullmq": ">=4.0.0",
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
