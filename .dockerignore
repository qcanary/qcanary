# ── .dockerignore ─────────────────────────────────────────────────
# Keep builds fast and images lean

.git
.gitignore
node_modules
dist
.next
*.tsbuildinfo

# Local OS / editor files
.DS_Store
Thumbs.db

# Environment files (never in images)
.env
.env.local
.env.production
.env.*.local

# IDE / editor
.idea
.vscode
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Test / coverage
coverage
.nyc_output

# Temp
tmp/
