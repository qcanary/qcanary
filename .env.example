# ────────────────────────────────────────────────────────
# Qcanary Environment Variables
# Copy this to .env and fill in your values
# ────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Clerk
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Dodo Payments
DODO_PUBLISHABLE_KEY=pk_test_your_key_here
DODO_SECRET_KEY=sk_test_your_key_here
DODO_WEBHOOK_SECRET=whsec_your_secret_here
DODO_STARTER_PRODUCT_ID=prod_your_starter_product_id
DODO_PRO_PRODUCT_ID=prod_your_pro_product_id

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Qcanary <onboarding@resend.dev>

# App URLs
API_BASE_URL=
NEXT_PUBLIC_APP_URL=
APP_URL=https://qcanary.dev
NEXT_PUBLIC_SITE_URL=https://qcanary.dev

# CORS: comma-separated allowed origins (e.g. https://qcanary.dev,https://www.qcanary.dev)
ALLOWED_ORIGINS=

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Sentry (optional)
SENTRY_DSN=

# CRON secret for notification endpoints
CRON_SECRET=hXm7z3itFgiKo6wDpyZbWqTyEj1GhfRNCSl3JnGXnEo=
