{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "reticle": {
      "command": "npx",
      "args": [
        "-y",
        "@reticlehq/server",
        "mcp"
      ]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp"
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    }
  }
}
